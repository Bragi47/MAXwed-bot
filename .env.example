# Токен
# Вариант A: через setup_encrypt.py (рекомендуется)
#   python setup_encrypt.py  → создаст key.bin + token.enc
#   ключ хранить только на сервере
#
# Вариант B: напрямую в .env (проще, но менее безопасно)
BOT_TOKEN=your_telegram_bot_token_here

# Веб-версия MAX (Mini App URL, открывается в Telegram)
WEB_URL=https://web.max.ru/

# Прокси (если требуется)
# PROXY_URL=socks5://user:pass@host:port
# PROXY_URL=http://user:pass@host:port
